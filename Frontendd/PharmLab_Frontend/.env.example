# Backend API Configuration
# Point to your backend API server
VITE_API_BASE_URL=http://localhost:5000

# Alternative name for compatibility
# VITE_API_BASE=http://localhost:5000

# Socket.io server URL (usually same as backend)
VITE_SOCKET_URL=http://localhost:5000

# API timeout in milliseconds
VITE_API_TIMEOUT=30000

# Application name
VITE_APP_NAME=PharmLab

# Application version
VITE_APP_VERSION=1.0.0

# Production environment flag
VITE_ENV=development

# Enable debug logging in development
VITE_DEBUG=true

# Production build note:
# For Render deployment, update VITE_API_BASE_URL to your backend URL
# Example: VITE_API_BASE_URL=https://your-backend.onrender.com
